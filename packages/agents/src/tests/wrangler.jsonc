      },
      {
        "class_name": "TestWaitConnectionsAgent",
        "name": "TestWaitConnectionsAgent"
      },
      {
        "class_name": "TestSubAgentParent",
        "name": "TestSubAgentParent"
      },
      {
        "class_name": "CustomBoundSubAgentParent",
        "name": "CUSTOM_BOUND_SUB_AGENT_PARENT"
